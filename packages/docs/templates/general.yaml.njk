id: "{{ pageId }}"
type: Box
events:
  onInit:
    - id: set_session_id
      type: SetGlobal
      skip:
        _not:
          _eq:
            - _global: session_id
            - null
      params:
        session_id:
          _random:
            type: string
            length: 16
properties:
  title: {{ pageTitle }}
blocks:
  - id: {{ pageId }}_page
    type: PageSiderMenu
    properties:
      title: {{ pageTitle }}
      darkModeToggle: true
      menu:
        forceSubMenuRender: true
      sider:
        width: 256px
        initialCollapsed:
          _or:
            - _eq:
                - _media: size
                - md
            - _eq:
                - _media: size
                - lg
      breadcrumb:
        list:
          - _ref: version.yaml
      {% if section %}
          - {{ section }}
          - {{ pageTitle }}
      {% endif %}

    style:
      .layout:
        background: var(--ant-color-bg-container)
      .footer:
        background: var(--ant-color-bg-container)
        padding: 16px 0px 0px 0px

    slots:
      header:
        blocks:
          _ref: templates/header.yaml
      footer:
        blocks:
          _ref:
            path: templates/footer.yaml.njk
            vars:
              hideFeedback:
                _var: hideFeedback
              filePath:
                _var: filePath
              pageId:
                _var: pageId

      content:
        justify: center
        blocks:
          - id: max_width
            type: Box
            layout:
              {% if fullWidth %}
              flex: 1 1 auto
              {% else %}
              flex: 0 1 800px
              {% endif %}
            style:
              minWidth: 0
              overflow: hidden
            blocks:
              {% if pageTitle %}
              - id: page_title
                type: Title
                properties:
                  content:
                    _var: pageTitle
              {% endif %}
              - id: content
                type: Box
                layout:
                  gap: 16
                blocks:
                  _var: content
