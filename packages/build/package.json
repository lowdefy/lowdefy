{
  "name": "@lowdefy/build",
  "version": "4.7.1",
  "license": "Apache-2.0",
  "description": "",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    },
    {
      "name": "Johann Möller",
      "url": "https://github.com/JohannMoller"
    },
    {
      "name": "Sandile Memela",
      "url": "https://github.com/sah-memela"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "bin": {
    "lowdefy-build": "./dist/scripts/run.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./dev": "./dist/indexDev.js",
    "./buildTestPage": "./dist/build/full/buildTestPage.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../.swcrc --cli-config-file ../../.swc-cli.json && node dist/scripts/generateDefaultTypes.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "start": "node dist/scripts/run.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:u": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=snapshots -- -u"
  },
  "dependencies": {
    "@lowdefy/ajv": "workspace:*",
    "@lowdefy/block-utils": "workspace:*",
    "@lowdefy/blocks-basic": "workspace:*",
    "@lowdefy/blocks-loaders": "workspace:*",
    "@lowdefy/errors": "workspace:*",
    "@lowdefy/helpers": "workspace:*",
    "@lowdefy/node-utils": "workspace:*",
    "@lowdefy/nunjucks": "workspace:*",
    "@lowdefy/operators": "workspace:*",
    "@lowdefy/operators-js": "workspace:*",
    "ajv": "8.12.0",
    "json5": "2.2.3",
    "picomatch": "4.0.3",
    "semver": "7.5.4",
    "tar": "7.5.11",
    "yaml": "2.3.4",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@jest/globals": "28.1.3",
    "@lowdefy/actions-core": "workspace:*",
    "@lowdefy/actions-pdf-make": "workspace:*",
    "@lowdefy/blocks-aggrid": "workspace:*",
    "@lowdefy/blocks-antd": "workspace:*",
    "@lowdefy/blocks-echarts": "workspace:*",
    "@lowdefy/blocks-google-maps": "workspace:*",
    "@lowdefy/blocks-markdown": "workspace:*",
    "@lowdefy/blocks-qr": "workspace:*",
    "@lowdefy/connection-axios-http": "workspace:*",
    "@lowdefy/connection-elasticsearch": "workspace:*",
    "@lowdefy/connection-google-sheets": "workspace:*",
    "@lowdefy/connection-knex": "workspace:*",
    "@lowdefy/connection-mongodb": "workspace:*",
    "@lowdefy/connection-redis": "workspace:*",
    "@lowdefy/connection-sendgrid": "workspace:*",
    "@lowdefy/connection-stripe": "workspace:*",
    "@lowdefy/connection-test": "workspace:*",
    "@lowdefy/logger": "workspace:*",
    "@lowdefy/operators-change-case": "workspace:*",
    "@lowdefy/operators-dayjs": "workspace:*",
    "@lowdefy/operators-diff": "workspace:*",
    "@lowdefy/operators-jsonata": "workspace:*",
    "@lowdefy/operators-mql": "workspace:*",
    "@lowdefy/operators-nunjucks": "workspace:*",
    "@lowdefy/operators-uuid": "workspace:*",
    "@lowdefy/operators-yaml": "workspace:*",
    "@lowdefy/plugin-auth0": "workspace:*",
    "@lowdefy/plugin-aws": "workspace:*",
    "@lowdefy/plugin-csv": "workspace:*",
    "@lowdefy/plugin-next-auth": "workspace:*",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@swc/jest": "0.2.39",
    "jest": "28.1.3",
    "pino": "8.16.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
