{
  "name": "@lowdefy/blocks-echarts",
  "version": "4.5.2",
  "license": "Apache-2.0",
  "description": "ECharts Blocks for Lowdefy.",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy",
    "lowdefy blocks",
    "echarts",
    "charts",
    "lowdefy plugin"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    },
    {
      "name": "Sandile Memela",
      "url": "https://github.com/sah-memela"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./blocks": "./dist/blocks.js",
    "./schemas": "./dist/schemas.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../../../.swcrc --delete-dir-on-start && pnpm copyfiles",
    "clean": "rm -rf dist",
    "copyfiles": "copyfiles -u 1 \"./src/**/*\" dist -e \"./src/**/*.js\" -e \"./src/**/*.yaml\" -e \"./src/**/*.snap\"",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lowdefy/block-utils": "4.5.2",
    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@swc/cli": "0.1.63",
    "@swc/core": "1.3.99",
    "copyfiles": "2.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "packageExtensions": {
      "echarts-for-react": {
        "dependencies": {
          "tslib": "*"
        }
      }
    }
  }
}
