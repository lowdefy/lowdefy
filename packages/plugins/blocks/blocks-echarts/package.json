{
  "name": "@lowdefy/blocks-echarts",
  "version": "4.7.3",
  "license": "Apache-2.0",
  "description": "ECharts Blocks for Lowdefy.",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy",
    "lowdefy blocks",
    "echarts",
    "charts",
    "lowdefy plugin"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    },
    {
      "name": "Sandile Memela",
      "url": "https://github.com/sah-memela"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./blocks": "./dist/blocks.js",
    "./metas": "./dist/metas.js",
    "./e2e": "./dist/e2e.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../../../.swcrc --cli-config-file ../../../../.swc-cli.json && pnpm copyfiles",
    "clean": "rm -rf dist",
    "copyfiles": "copyfiles -u 1 \"./src/**/*\" dist -e \"./src/**/*.js\" -e \"./src/**/*.yaml\" -e \"./src/**/*.snap\"",
    "e2e": "playwright test --config e2e/playwright.config.js",
    "e2e:ui": "playwright test --config e2e/playwright.config.js --ui",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lowdefy/block-utils": "4.7.3",
    "echarts": "6.0.0",
    "echarts-for-react": "3.0.5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@lowdefy/block-dev-e2e": "4.7.3",
    "@lowdefy/e2e-utils": "4.7.3",
    "@playwright/test": "1.50.1",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "copyfiles": "2.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "packageExtensions": {
      "echarts-for-react": {
        "dependencies": {
          "tslib": "*"
        }
      }
    }
  }
}
