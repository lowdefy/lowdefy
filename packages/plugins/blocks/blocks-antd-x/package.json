{
  "name": "@lowdefy/blocks-antd-x",
  "version": "4.7.1",
  "license": "Apache-2.0",
  "description": "Lowdefy Ant Design X Blocks",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy",
    "lowdefy blocks",
    "antd",
    "ant design x",
    "lowdefy plugin"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "exports": {
    "./blocks": "./dist/blocks.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../../../.swcrc --cli-config-file ../../../../.swc-cli.json && pnpm copyfiles",
    "clean": "rm -rf dist",
    "copyfiles": "copyfiles -u 1 \"./src/**/*\" dist -e \"./src/**/*.js\" -e \"./src/**/*.yaml\" -e \"./src/**/*.snap\"",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.118",
    "@ant-design/icons": "6.1.0",
    "@ant-design/x": "2.4.0",
    "@ant-design/x-markdown": "2.4.0",
    "@lowdefy/block-utils": "4.7.3",
    "@lowdefy/helpers": "4.7.3",
    "ai": "6.0.116"
  },
  "devDependencies": {
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "copyfiles": "2.4.1"
  },
  "peerDependencies": {
    "antd": "6.3.1",
    "react": "18.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
