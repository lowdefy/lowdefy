{
  "name": "@lowdefy/blocks-diff",
  "version": "5.0.0",
  "license": "Apache-2.0",
  "description": "Lowdefy diff blocks — list, side-by-side, timeline, and git-diff views for before/after object comparisons.",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy",
    "lowdefy blocks",
    "diff",
    "lowdefy plugin"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./blocks": "./dist/blocks.js",
    "./e2e": "./dist/e2e.js",
    "./metas": "./dist/metas.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../../../.swcrc --cli-config-file ../../../../.swc-cli.json && pnpm copyfiles",
    "clean": "rm -rf dist",
    "copyfiles": "copyfiles -u 1 \"./src/**/*\" dist -e \"./src/**/*.js\" -e \"./src/**/*.yaml\" -e \"./src/**/*.snap\"",
    "e2e": "playwright test --config e2e/playwright.config.js",
    "e2e:ui": "playwright test --config e2e/playwright.config.js --ui",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.0",
    "@lowdefy/block-utils": "5.0.0",
    "@lowdefy/helpers": "5.0.0",
    "dayjs": "1.11.19",
    "diff": "5.2.2",
    "microdiff": "1.4.0",
    "pluralize": "8.0.0",
    "yaml": "2.3.4"
  },
  "peerDependencies": {
    "antd": ">=6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@lowdefy/block-dev-e2e": "5.0.0",
    "@lowdefy/e2e-utils": "5.0.0",
    "@playwright/test": "1.50.1",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "copyfiles": "2.4.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
