{
  "name": "@lowdefy/blocks-antd",
  "version": "4.7.0",
  "license": "Apache-2.0",
  "description": "Lowdefy Ant Design Blocks",
  "homepage": "https://lowdefy.com",
  "keywords": [
    "lowdefy",
    "lowdefy blocks",
    "antd",
    "ant design",
    "lowdefy plugin"
  ],
  "bugs": {
    "url": "https://github.com/lowdefy/lowdefy/issues"
  },
  "contributors": [
    {
      "name": "Sam Tolmay",
      "url": "https://github.com/SamTolmay"
    },
    {
      "name": "Gerrie van Wyk",
      "url": "https://github.com/Gervwyk"
    },
    {
      "name": "Sandile Memela",
      "url": "https://github.com/sah-memela"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lowdefy/lowdefy.git"
  },
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./blocks": "./dist/blocks.js",
    "./e2e": "./dist/e2e.js",
    "./metas": "./dist/metas.js",
    "./types": "./dist/types.json"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../../../.swcrc --cli-config-file ../../../../.swc-cli.json && pnpm copyfiles && extract-plugin-types",
    "clean": "rm -rf dist",
    "copyfiles": "copyfiles -u 1 \"./src/**/*\" dist -e \"./src/**/*.js\" -e \"./src/**/*.yaml\" -e \"./src/**/*.snap\"",
    "e2e": "playwright test --config e2e/playwright.config.js",
    "e2e:ui": "playwright test --config e2e/playwright.config.js --ui",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.0",
    "@lowdefy/block-utils": "4.7.0",
    "@lowdefy/helpers": "4.7.0",
    "@rc-component/motion": "1.3.1",
    "antd": "6.3.1",
    "classnames": "2.3.2",
    "dayjs": "1.11.19",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@lowdefy/block-dev-e2e": "4.7.0",
    "@lowdefy/e2e-utils": "4.7.0",
    "@lowdefy/node-utils": "4.7.0",
    "@playwright/test": "1.50.1",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "copyfiles": "2.4.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
